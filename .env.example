# ============================================================
# SK WebTech — environment template
# Copy this file to .env.local and fill in REAL values there.
# NEVER commit real credentials to git — .env.local is gitignored.
# ============================================================

# --- Contact form email (SMTP) ---
# Example using Gmail SMTP with an App Password:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
CONTACT_EMAIL_RECIPIENT=your-email@gmail.com

# --- MySQL database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=skwebtech

# --- Admin panel security ---
# Used ONLY to seed the first admin user (username: admin) when the
# admin_users table is empty. After that, change the password from the
# admin dashboard (Security section) — the DB copy is what counts.
ADMIN_PASSWORD=A

# Secret used to sign admin session cookies. Use a long random string,
# e.g. run:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET=your-long-random-secret

# --- AI chatbot ---
GEMINI_API_KEY=your-gemini-api-key

# --- PhonePe (this domain is PhonePe's approved payment-receiving URL) ---
PHONEPE_ENV=production
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1

# --- Gateway relay (shared secret with the app(s) that hand off checkout here) ---
GATEWAY_RELAY_SECRET=

# --- Alternative SMTP providers ---
# Example using a free SendGrid account:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# Example using a free Mailgun account:
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@sandbox1234567890.mailgun.org
# SMTP_PASS=your-mailgun-password
