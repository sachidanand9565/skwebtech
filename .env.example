# Contact form email settings
# Replace these values with your SMTP provider credentials.

# Example using Gmail SMTP with an App Password:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# CONTACT_EMAIL_RECIPIENT=sachi274406@gmail.com

# Example using a free SendGrid account:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# CONTACT_EMAIL_RECIPIENT=sachi274406@gmail.com

# Example using a free Mailgun account:
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@sandbox1234567890.mailgun.org
# SMTP_PASS=your-mailgun-password
# CONTACT_EMAIL_RECIPIENT=sachi274406@gmail.com
