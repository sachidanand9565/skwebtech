    "n-msg-welcome-1001": {
      "id": "n-msg-welcome-1001",
      "type": "message",
      "data": {
        "label": "Message",
        "text": "🚀 *Welcome to SK WebTech!*\n\nHi there! We build websites, e-commerce stores, mobile apps & more.\n\nHow can we help you today? Please choose an option below 👇",
        "buttons": [
          {
            "id": "1",
            "text": "📋 Get a Quote"
          },
          {
            "id": "2",
            "text": "🌐 Our Services"
          },
          {
            "id": "3",
            "text": "☎ Talk to Expert"
          }
        ],
        "save_id_as": "intent"
      },
      "position": {
        "x": -1010,
        "y": -180
      },
      "width": 232,
      "height": 223
    },
    "n-ask-name-1002": {
      "id": "n-ask-name-1002",
      "type": "ask_question",
      "data": {
        "label": "Ask Question",
        "question": "Great! 😊 First, what's your name?",
        "save_as": "user_name",
        "validation": "any"
      },
      "position": {
        "x": -700,
        "y": -230
      },
      "width": 224,
      "height": 110
    },
    "n-list-services-1003": {
      "id": "n-list-services-1003",
      "type": "dynamic_list",
      "data": {
        "label": "Dynamic List",
        "url": "https://www.skwebtech.in/api/chatbot/services",
        "method": "POST",
        "headers": "",
        "req_body": "",
        "items_path": "",
        "id_field": "id",
        "title_field": "name",
        "desc_field": "price",
        "body": "Thanks {{var.user_name}}! 🙌\nPlease select the service you're interested in 👇",
        "button_text": "Select Service",
        "save_response_as": "",
        "save_id_as": "service_id",
        "save_title_as": "service_name"
      },
      "position": {
        "x": -420,
        "y": -190
      },
      "width": 232,
      "height": 168
    },
    "n-ask-requirement-1004": {
      "id": "n-ask-requirement-1004",
      "type": "ask_question",
      "data": {
        "label": "Ask Question",
        "question": "📝 Please describe your project or requirement in a few lines.\n\n(e.g. \"I need an e-commerce website for my clothing brand with payment gateway\")",
