    "n-msg-confirm-1006": {
      "id": "n-msg-confirm-1006",
      "type": "message",
      "data": {
        "label": "Message",
        "text": "Please confirm your request 👇\n\n👤 *Name:* {{var.user_name}}\n📱 *Mobile:* {{contact.phone}}\n🛠 *Service:* {{var.service_name}}\n📝 *Requirement:* {{var.requirement}}\n📧 *Email:* {{var.email}}",
        "buttons": [
          {
            "id": "btn_confirm",
            "text": "✅ Confirm Request"
          },
          {
            "id": "btn_change",
            "text": "🔄 Change Service"
          }
        ],
        "save_id_as": "confirm_choice"
      },
      "position": {
        "x": 430,
        "y": -240
      },
      "width": 232,
      "height": 223
    },
    "n-api-lead-1007": {
      "id": "n-api-lead-1007",
      "type": "api",
      "data": {
        "label": "API Request",
        "method": "POST",
        "url": "https://www.skwebtech.in/api/chatbot/lead",
        "body": "{\n  \"name\": \"{{var.user_name}}\",\n  \"mobile\": \"{{contact.phone}}\",\n  \"service\": \"{{var.service_id}}\",\n  \"service_name\": \"{{var.service_name}}\",\n  \"requirement\": \"{{var.requirement}}\",\n  \"email\": \"{{var.email}}\",\n  \"source\": \"WhatsApp Bot\"\n}",
        "save_as": "",
        "extract_fields": [
          {
            "path": "lead_id",
            "variable": "lead_id"
          }
        ]
      },
